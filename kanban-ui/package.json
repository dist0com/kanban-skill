{
  "name": "kanban-skill-ui",
  "version": "0.1.1",
  "description": "Local kanban board UI — run it on your machine to see the board and spawn agents (claude -p) to do the kanban work. Files in docs/kanban/ stay the source of truth.",
  "keywords": ["kanban", "claude", "claude-code", "agent", "markdown", "board", "ui"],
  "license": "Apache-2.0",
  "homepage": "https://kanban-skill.pages.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dist0com/kanban-skill.git",
    "directory": "kanban-ui"
  },
  "bin": {
    "kanban-skill-ui": "bin/kanban-ui.mjs"
  },
  "files": [
    "bin/",
    ".next/standalone/"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:standalone": "next build && node scripts/copy-standalone-assets.mjs",
    "start": "next start",
    "lint": "next lint",
    "prepublishOnly": "npm run build:standalone"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.7.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^3.6.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
